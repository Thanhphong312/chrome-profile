{
  "name": "chrome-proxy-manager",
  "version": "1.0.0",
  "description": "Manage multiple Chrome profiles with isolated proxies",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.yourcompany.chromeproxymanager",
    "productName": "Chrome Proxy Manager",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "database/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "config/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "crypto-js": "^4.2.0",
    "proxy-chain": "^2.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.37",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  }
}
